# Copia este fichero a .env.local y ajusta lo que necesites.
# apsis carga .env.<ENVIRONMENT> (ENVIRONMENT=local por defecto).

ENVIRONMENT=local

# Base de datos (PostGIS). DATABASE_URL se deriva de las partes si se deja vacia.
DB_HOST=localhost
DB_PORT=5432
DB_USER=apsis
DB_PASSWORD=apsis
DB_NAME=apsis_dev

# Pool de conexiones.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Scheduler de jobs (segundos). Invariante: JOB_LEASE_SECONDS >= 2 * JOB_HANDLER_TIMEOUT_SECONDS.
JOB_POLL_INTERVAL_SECONDS=5
JOB_LEASE_SECONDS=120
JOB_HANDLER_TIMEOUT_SECONDS=55

# Outbox transaccional.
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_HANDLER_TIMEOUT_SECONDS=30
OUTBOX_MAX_RETRIES=8

# Fuente de TLEs (CelesTrak). No refrescar mas de una vez cada 2h (devuelve 403).
CELESTRAK_GROUP=active

# Ventana (horas) que recalcula el handler recompute_passes.
PASS_PREDICTION_HORIZON_HOURS=48
